"fill":"#6ee7b7","fillOpacity":"0.8"}],["$","circle",null,{"cx":"36","cy":"7","r":"0.7","fill":"#6ee7b7","fillOpacity":"0.5"}]]}],["$","span",null,{"style":{"fontSize":14.56,"fontWeight":800,"letterSpacing":"-0.03em","lineHeight":1,"color":"#f0f0f5"},"children":["Tag",["$","span",null,{"style":{"color":"#10b981"},"children":"Mint"}]]}]]}],["$","p",null,{"className":"text-xs","style":{"color":"#404060"},"children":"© 2025 TagMint  ·  Results typically visible within 2–3 weeks"}],["$","div",null,{"className":"flex gap-6","children":[["$","$L3",null,{"href":"/#how-it-works","className":"text-xs transition-colors","style":{"color":"#404060"},"children":"How It Works"}],["$","$L3",null,{"href":"/#results","className":"text-xs transition-colors","style":{"color":"#404060"},"children":"Results"}],["$","$L3",null,{"href":"/#pricing","className":"text-xs transition-colors","style":{"color":"#404060"},"children":"Pricing"}],["$","$L3",null,{"href":"/blog","className":"text-xs transition-colors","style":{"color":"#404060"},"children":"Blog"}]]}]]}]}]
